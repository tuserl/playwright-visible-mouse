/* 1. The wrapper overlays the screen and handles the high-visibility outlines */
#demoMouseWrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 99999;

  filter:
    drop-shadow(1px 0px 0px #000000) drop-shadow(-1px 0px 0px #000000) drop-shadow(0px 1px 0px #000000) drop-shadow(0px -1px 0px #000000) drop-shadow(3px 4px 4px rgba(0, 0, 0, 0.35));
}

/* 2. The inner element handles the sleek pointer geometry */
#demoMouse {
  position: absolute;
  width: 22px;
  height: 31px;
  pointer-events: none;
  background: #ffffff;
  clip-path: polygon(0% 0%, 0% 100%, 26% 74%, 55% 100%, 72% 88%, 43% 62%, 84% 62%);
  transform-origin: 0% 0%;

  transition:
    background 0.3s ease,
    scale 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 3. NEW: The radar ripple effect that spawns on click */
.click-ripple {
  position: absolute;
  width: 4px;
  height: 4px;
  background: transparent;
  border: 2.5px solid currentColor;
  /* Automatically inherits the mouse's color */
  border-radius: 50%;
  transform: translate(-50%, -50%);
  /* Centers the ring perfectly on the arrow's tip */
  pointer-events: none;
  animation: radar-pulse 0.4s ease-out forwards;
}

@keyframes radar-pulse {
  0% {
    width: 4px;
    height: 4px;
    opacity: 1;
  }

  100% {
    width: 40px;
    height: 40px;
    opacity: 0;
  }
}
